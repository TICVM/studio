rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_profiles/$(request.auth.uid));
    }

    // --- REGRAS DE COLEÇÃO ---

    match /admin_profiles/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(adminId);
      allow update: if isOwner(adminId);
      allow delete: if isAdmin();
    }

    match /sectors/{sectorId} {
      allow read: if true; // Setores são públicos para organização do carômetro
      allow write: if isAdmin();
    }

    match /employees/{employeeId} {
      // Admins podem ler tudo. Usuários anônimos/públicos só podem ler ativos.
      // O Firestore aplicará isso como um filtro obrigatório em consultas de listagem.
      allow read: if isAdmin() || (resource.data.status == 'ativo');
      allow write: if isAdmin();
    }
  }
}