rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_profiles/$(request.auth.uid));
    }

    // --- REGRAS DE COLEÇÃO ---

    match /admin_profiles/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(adminId);
      allow update: if isOwner(adminId) && resource != null;
      allow delete: if isAdmin();
    }

    match /sectors/{sectorId} {
      allow read: if isSignedIn(); // Permitir leitura para usuários logados (incluindo funcionários/admins)
      allow write: if isAdmin();
    }

    match /employees/{employeeId} {
      // Permite leitura individual se for admin ou se o funcionário estiver ativo
      allow get: if isAdmin() || (resource != null && resource.data.status == 'ativo');
      
      // Permite listagem se for admin OU se a consulta filtrar apenas por funcionários ativos
      // Isso suporta o padrão QAP (Query as Permission)
      allow list: if isAdmin() || (request.query.limit <= 100 && resource.data.status == 'ativo');
      
      allow write: if isAdmin();
    }
  }
}